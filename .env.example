# Database
MYSQL_DATABASE=medicore_hms
MYSQL_USER=medicore
MYSQL_PASSWORD=change_this_password
MYSQL_ROOT_PASSWORD=change_this_root_password

# App ports
BACKEND_PORT=8080
FRONTEND_PORT=80

# Security
# Must be a long Base64 value for HS256.
APP_JWT_SECRET=replace_with_a_long_base64_secret
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_DAYS=7
APP_DISABLE_SEEDED_USERS=true
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_NAME=Platform Admin
APP_BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
APP_BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_password_12_plus

# CORS
# For production, set your real frontend domain(s), comma-separated.
APP_CORS_ALLOWED_ORIGINS=http://localhost:80
